<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bar_background"
    android:padding="16dp">

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/holyrics_sheet_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/bar_text" />

        <Button
            android:id="@+id/btnHolyricsClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/holyrics_close"
            android:textSize="14sp"
            app:backgroundTint="@color/accent_secondary" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nav_button"
        android:layout_marginBottom="12dp" />

    <!-- Scrollable song buttons -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/llSongButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp" />

    </HorizontalScrollView>

</LinearLayout>
