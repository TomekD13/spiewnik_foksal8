<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bar_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/bar_text"
            android:paddingBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/nav_button"
            android:layout_marginBottom="16dp" />

        <!-- Holyrics section label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/holyrics_section_title"
            android:textSize="15sp"
            android:textColor="@color/bar_text"
            android:paddingBottom="8dp" />

        <!-- Scan QR: fills IP + token from a Holyrics QR code -->
        <Button
            android:id="@+id/btnScanHolyricsQr"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/holyrics_scan_qr"
            android:textSize="15sp"
            app:icon="@drawable/ic_qr_scan"
            app:iconGravity="textStart"
            app:backgroundTint="@color/accent_secondary"
            android:layout_marginBottom="12dp" />

        <!-- IP label + field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/holyrics_ip_label"
            android:textSize="13sp"
            android:textColor="@color/bar_text"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/etHolyricsIp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="text"
            android:hint="@string/holyrics_ip_hint"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:background="@drawable/input_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="12dp" />

        <!-- Token label + field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/holyrics_token_label"
            android:textSize="13sp"
            android:textColor="@color/bar_text"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etHolyricsToken"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:inputType="textPassword"
                android:hint="@string/holyrics_token_hint"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:background="@drawable/input_background"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <ImageButton
                android:id="@+id/btnRevealToken"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_visibility"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/holyrics_token_reveal" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSaveHolyrics"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/holyrics_save"
            android:textSize="15sp"
            app:backgroundTint="@color/accent_secondary"
            android:layout_marginBottom="12dp" />

        <!-- Auto-follow toggle -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swAutoFollow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/holyrics_auto_follow"
            android:textSize="15sp"
            android:textColor="@color/bar_text"
            app:thumbTint="@color/holyrics_switch"
            app:trackTint="@color/holyrics_switch"
            android:layout_marginBottom="12dp" />

        <!-- Send-to-Holyrics toggle -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swHolyricsSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/holyrics_send_toggle"
            android:textSize="15sp"
            android:textColor="@color/bar_text"
            app:thumbTint="@color/holyrics_switch"
            app:trackTint="@color/holyrics_switch"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/nav_button"
            android:layout_marginBottom="16dp" />

        <!-- Help / user manual -->
        <Button
            android:id="@+id/btnHelp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/help_button"
            android:textSize="15sp"
            app:backgroundTint="@color/accent_secondary"
            android:layout_marginBottom="12dp" />

        <!-- Crash logging toggle -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swCrashLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/crash_log_toggle"
            android:textSize="15sp"
            android:textColor="@color/bar_text"
            app:thumbTint="@color/holyrics_switch"
            app:trackTint="@color/holyrics_switch"
            android:layout_marginBottom="12dp" />

        <!-- Share crash log -->
        <Button
            android:id="@+id/btnShareCrashLog"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/crash_log_share"
            android:textSize="15sp"
            app:backgroundTint="@color/accent_secondary"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/nav_button"
            android:layout_marginBottom="12dp" />

        <!-- App info -->
        <TextView
            android:id="@+id/tvAppInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/nav_button_text_disabled"
            android:paddingBottom="16dp" />

        <!-- Close button -->
        <Button
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/settings_close"
            android:textSize="15sp"
            app:backgroundTint="@color/accent" />

    </LinearLayout>
</ScrollView>
