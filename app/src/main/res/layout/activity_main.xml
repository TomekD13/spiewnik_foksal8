<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:keepScreenOn="true">

    <!-- ── Top info bar ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bar_background"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvSongInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="18sp"
            android:textColor="@color/bar_text"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/app_name" />

        <TextView
            android:id="@+id/tvPageInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/bar_text"
            android:paddingStart="12dp"
            android:paddingEnd="4dp" />

        <Button
            android:id="@+id/btnSelect"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:text="@string/btn_hide_bar"
            android:textSize="14sp"
            android:padding="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            app:backgroundTint="@color/accent" />

        <Button
            android:id="@+id/btnHolyrics"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:text="@string/btn_holyrics"
            android:textSize="14sp"
            android:padding="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            app:backgroundTint="@color/accent_secondary" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:text="@string/btn_settings"
            android:textSize="20sp"
            android:padding="0dp"
            app:backgroundTint="@color/bar_background" />
    </LinearLayout>

    <!-- ── Input row ── -->
    <LinearLayout
        android:id="@+id/inputRow"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/input_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Number input -->
        <EditText
            android:id="@+id/etNumber"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:hint="@string/hint_number"
            android:inputType="number"
            android:imeOptions="actionGo"
            android:maxLength="4"
            android:textSize="22sp"
            android:textAlignment="center"
            android:background="@drawable/input_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnGo"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:text="@string/btn_go"
            android:textSize="18sp"
            app:backgroundTint="@color/accent" />

        <!-- Title search -->
        <AutoCompleteTextView
            android:id="@+id/actvTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:hint="@string/hint_search"
            android:inputType="text"
            android:textSize="16sp"
            android:completionThreshold="1"
            android:background="@drawable/input_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <!-- Nav mode toggle -->
        <Button
            android:id="@+id/btnNavMode"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:text="@string/nav_spread"
            android:textSize="14sp"
            app:backgroundTint="@color/accent_secondary" />

    </LinearLayout>

    <!-- ── Critical error banner (hidden by default) ── -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textSize="15sp"
        android:textColor="@color/error_text"
        android:background="@color/error_background"
        android:visibility="gone"
        android:gravity="center" />

    <!-- ── PDF spread area ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left nav button -->
        <Button
            android:id="@+id/btnPrev"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="◀"
            android:textSize="24sp"
            app:backgroundTint="@color/nav_button_tint"
            android:textColor="@color/nav_button_text_tint" />

        <!-- PDF pages container — touch target for zoom/pan -->
        <LinearLayout
            android:id="@+id/pdfContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Left page -->
            <ImageView
                android:id="@+id/ivLeft"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scaleType="fitCenter"
                android:background="@color/page_background"
                android:contentDescription="@string/cd_left_page" />

            <!-- Right page -->
            <ImageView
                android:id="@+id/ivRight"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scaleType="fitCenter"
                android:background="@color/page_background"
                android:contentDescription="@string/cd_right_page"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Right nav button -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="▶"
            android:textSize="24sp"
            app:backgroundTint="@color/nav_button_tint"
            android:textColor="@color/nav_button_text_tint" />
    </LinearLayout>

</LinearLayout>
